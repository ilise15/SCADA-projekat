<Window x:Class="ScadaGUI.Views.FilterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Filtriranje podataka" Height="560" Width="700"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F5F5F5" CornerRadius="4" Padding="12" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Tag:" Grid.Row="0" Grid.Column="0" Margin="4,0,4,4" FontWeight="SemiBold"/>
                <ComboBox x:Name="TagFilterBox" Grid.Row="1" Grid.Column="0" Height="32" Margin="4,0,4,8"/>

                <TextBlock Text="Od datuma:" Grid.Row="0" Grid.Column="1" Margin="4,0,4,4" FontWeight="SemiBold"/>
                <DatePicker x:Name="FromDate" Grid.Row="1" Grid.Column="1" Height="32" Margin="4,0,4,8"/>

                <TextBlock Text="Do datuma:" Grid.Row="0" Grid.Column="2" Margin="4,0,4,4" FontWeight="SemiBold"/>
                <DatePicker x:Name="ToDate" Grid.Row="1" Grid.Column="2" Height="32" Margin="4,0,4,8"/>

                <TextBlock Text="Min vrednost:" Grid.Row="2" Grid.Column="0" Margin="4,0,4,4" FontWeight="SemiBold"/>
                <TextBox x:Name="MinValBox" Grid.Row="3" Grid.Column="0" Height="32" Margin="4,4,4,0"
                         BorderBrush="#BDBDBD" BorderThickness="1" Padding="6,4"/>

                <TextBlock Text="Maks vrednost:" Grid.Row="2" Grid.Column="1" Margin="4,0,4,4" FontWeight="SemiBold"/>
                <TextBox x:Name="MaxValBox" Grid.Row="3" Grid.Column="1" Height="32" Margin="4,4,4,0"
                         BorderBrush="#BDBDBD" BorderThickness="1" Padding="6,4"/>

                <StackPanel Grid.Row="3" Grid.Column="2" Orientation="Horizontal"
                            Margin="4,4,4,0" VerticalAlignment="Center">
                    <Button Content="Filtriraj" Click="Filter_Click" Padding="12,6"
                            Background="#1976D2" Foreground="White" BorderThickness="0"
                            Cursor="Hand" Margin="0,0,6,0"/>
                    <Button Content="Generiši TXT" Click="Generate_Click" Padding="12,6"
                            Background="#388E3C" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <DataGrid Grid.Row="1" x:Name="ResultsGrid" AutoGenerateColumns="False"
                  IsReadOnly="True" CanUserAddRows="False" FontSize="12" Margin="0,0,0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Tag" Binding="{Binding TagName}" Width="120"/>
                <DataGridTextColumn Header="Vrednost" Binding="{Binding Value, StringFormat=F3}" Width="100"/>
                <DataGridTextColumn Header="Vreme"
                    Binding="{Binding Timestamp, StringFormat=yyyy-MM-dd HH:mm:ss}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Button Grid.Row="2" Content="Zatvori" Click="Close_Click" HorizontalAlignment="Right"
                Padding="20,8" Background="#1976D2" Foreground="White"
                BorderThickness="0" Cursor="Hand" FontSize="13"/>
    </Grid>
</Window>
