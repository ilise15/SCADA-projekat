<Window x:Class="ScadaGUI.Views.WriteValueWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Upiši vrednost" Height="220" Width="340"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Border Margin="20" Padding="20" Background="White" CornerRadius="6"
            BorderBrush="#E0E0E0" BorderThickness="1">
        <StackPanel>
            <TextBlock x:Name="TagLabel" FontSize="14" FontWeight="SemiBold"
                       Foreground="#1976D2" Margin="0,0,0,12"/>
            <TextBlock Text="Nova vrednost:" FontSize="12" Foreground="#424242" Margin="0,0,0,4"/>
            <TextBox x:Name="ValueBox" Height="36" FontSize="14" Padding="8,6"
                     BorderBrush="#BDBDBD" BorderThickness="1" Margin="0,0,0,12"/>
            <TextBlock x:Name="ErrText" Foreground="Red" FontSize="11"
                       Margin="0,0,0,8" Visibility="Collapsed"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Otkaži" Click="Cancel_Click" Width="75" Height="34"
                        Margin="0,0,8,0" Background="#9E9E9E" Foreground="White"
                        BorderThickness="0" Cursor="Hand"/>
                <Button Content="Upiši" Click="Write_Click" Width="75" Height="34"
                        Background="#1976D2" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
