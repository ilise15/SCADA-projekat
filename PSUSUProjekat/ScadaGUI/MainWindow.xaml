<Window x:Class="ScadaGUI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ScadaGUI.ViewModels"
        Title="SCADA Sistem" Height="750" Width="1200"
        WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
    <Window.Background>
        <DynamicResource ResourceKey="BackgroundBrush"/>
    </Window.Background>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="200"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="{DynamicResource AccentBrush}" Padding="12,0">
            <DockPanel>
                <TextBlock Text="SCADA" FontSize="20" FontWeight="Bold"
                           Foreground="{DynamicResource AccentForegroundBrush}"
                           VerticalAlignment="Center" Margin="0,0,20,0"/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" DockPanel.Dock="Right">
                    <Button Content="{Binding AddTagLabel}" Command="{Binding AddTagCommand}"
                            Background="White" Foreground="#1976D2" Margin="4,0"
                            Padding="12,6" BorderThickness="0" Cursor="Hand"
                            ToolTip="Dodaj novi tag ili alarm"/>
                    <Button Content="{Binding ReportLabel}" Command="{Binding GenerateReportCommand}"
                            Background="White" Foreground="#1976D2" Margin="4,0"
                            Padding="12,6" BorderThickness="0" Cursor="Hand"/>
                    <Button Content="{Binding FilterLabel}" Command="{Binding ShowFilterCommand}"
                            Background="White" Foreground="#1976D2" Margin="4,0"
                            Padding="12,6" BorderThickness="0" Cursor="Hand"/>
                    <Button Content="{Binding ExportLabel}" Command="{Binding ExportConfigCommand}"
                            Background="White" Foreground="#1976D2" Margin="4,0"
                            Padding="12,6" BorderThickness="0" Cursor="Hand"/>
                    <Button Content="{Binding ImportLabel}" Command="{Binding ImportConfigCommand}"
                            Background="White" Foreground="#1976D2" Margin="4,0"
                            Padding="12,6" BorderThickness="0" Cursor="Hand"/>
                    <Button Content="{Binding SettingsLabel}" Click="Settings_Click"
                            Background="White" Foreground="#1976D2" Margin="4,0"
                            Padding="12,6" BorderThickness="0" Cursor="Hand"/>
                    <Button Content="{Binding LogoutLabel}" Command="{Binding LogoutCommand}"
                            Background="#EF5350" Foreground="White" Margin="4,0"
                            Padding="12,6" BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Tags Grid -->
        <Border Grid.Row="1" Margin="10,10,10,5" Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="{DynamicResource AccentBrush}"
                        CornerRadius="4,4,0,0" Padding="10,0">
                    <TextBlock Text="{Binding TagsLabel}" FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource AccentForegroundBrush}"
                               VerticalAlignment="Center"/>
                </Border>
                <DataGrid Grid.Row="1" ItemsSource="{Binding Tags}" AutoGenerateColumns="False"
                          IsReadOnly="True" CanUserAddRows="False" SelectionMode="Single"
                          Background="{DynamicResource PanelBrush}"
                          Foreground="{DynamicResource ForegroundBrush}"
                          GridLinesVisibility="Horizontal" BorderThickness="0" FontSize="13">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Tip" Binding="{Binding TagType}" Width="60"/>
                        <DataGridTextColumn Header="Ime" Binding="{Binding TagName}" Width="120"/>
                        <DataGridTextColumn Header="Opis" Binding="{Binding Description}" Width="200"/>
                        <DataGridTextColumn Header="I/O Adresa" Binding="{Binding IOAddress}" Width="90"/>
                        <DataGridTextColumn Header="Vrednost" Binding="{Binding DisplayValue}" Width="110"/>
                        <DataGridTemplateColumn Header="Alarm" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Ellipse Width="16" Height="16" Fill="{Binding AlarmColor}"
                                             HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Sken" Width="70">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding ScanStateText}"
                                               Foreground="{Binding ScanStateColor}"
                                               FontWeight="Bold" HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Akcije" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Detalji" Margin="2"
                                                Command="{Binding DataContext.ShowDetailsCommand,
                                                    RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Padding="8,3" FontSize="11" Cursor="Hand"
                                                Background="#1976D2" Foreground="White" BorderThickness="0"/>
                                        <Button Content="Scan" Margin="2"
                                                Command="{Binding DataContext.ToggleScanCommand,
                                                    RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Padding="8,3" FontSize="11" Cursor="Hand"
                                                Background="#388E3C" Foreground="White" BorderThickness="0"/>
                                        <Button Content="Upiši" Margin="2"
                                                Command="{Binding DataContext.WriteValueCommand,
                                                    RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Padding="8,3" FontSize="11" Cursor="Hand"
                                                Background="#F57C00" Foreground="White" BorderThickness="0"/>
                                        <Button Content="Istorija" Margin="2"
                                                Command="{Binding DataContext.ShowHistoryCommand,
                                                    RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Padding="8,3" FontSize="11" Cursor="Hand"
                                                Background="#7B1FA2" Foreground="White" BorderThickness="0"/>
                                        <Button Content="Ukloni" Margin="2"
                                                Command="{Binding DataContext.RemoveTagCommand,
                                                    RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Padding="8,3" FontSize="11" Cursor="Hand"
                                                Background="#D32F2F" Foreground="White" BorderThickness="0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Alarms Panel -->
        <Border Grid.Row="2" Margin="10,0,10,10" Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#D32F2F" CornerRadius="4,4,0,0" Padding="10,0">
                    <TextBlock Text="{Binding AlarmsLabel}" FontSize="13" FontWeight="Bold"
                               Foreground="White" VerticalAlignment="Center"/>
                </Border>
                <DataGrid Grid.Row="1" ItemsSource="{Binding RecentAlarms}" AutoGenerateColumns="False"
                          IsReadOnly="True" CanUserAddRows="False" FontSize="12"
                          Background="{DynamicResource PanelBrush}"
                          Foreground="{DynamicResource ForegroundBrush}"
                          BorderThickness="0" GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Tag" Binding="{Binding TagName}" Width="120"/>
                        <DataGridTextColumn Header="Poruka" Binding="{Binding Message}" Width="250"/>
                        <DataGridTextColumn Header="Vreme"
                            Binding="{Binding ActivatedAt, StringFormat=yyyy-MM-dd HH:mm:ss}" Width="160"/>
                        <DataGridTextColumn Header="Vrednost"
                            Binding="{Binding ValueAtActivation, StringFormat=F2}" Width="80"/>
                        <DataGridTemplateColumn Header="Potvrdi" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Acknowledge" Padding="6,3" FontSize="11"
                                            Background="#F57C00" Foreground="White" BorderThickness="0"
                                            Command="{Binding DataContext.AcknowledgeAlarmCommand,
                                                RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" Cursor="Hand"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Window>
